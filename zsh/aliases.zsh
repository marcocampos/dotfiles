# vi: filetype=zsh

#  files
alias ls="lsd"
alias l='ls -l'
alias la='ls -a'
alias ll="ls -lah"
alias lt='ls --tree'

# better "cat-ing"
alias cat="bat --style=full"
alias cats="bat --style=plain"

# tmux with nice colors
alias tmux="tmux -2"

# kubectx
alias kx="kubectx"
alias kxu="kubectx -u"

# text editor
alias v="nvim"
alias nv="nvim"
alias vi="nvim"
alias vim="nvim"

# terragrunt
alias tg="terragrunt"

# yt-dlp
alias dvf="yt-dlp -f 'bv*+ba'"
